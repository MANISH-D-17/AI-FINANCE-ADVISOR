# AI Finance Advisor — Environment Variables
# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL (recommended for production)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/finance_db

# SQLite fallback (used automatically when PostgreSQL is unavailable)
# DATABASE_URL=sqlite+aiosqlite:///./finance.db

# ─── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ─── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ─── AI / Gemini ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Optional Services ────────────────────────────────────────────────────────
# Upstash Redis (optional — for rate limiting persistence across restarts)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (optional — for email notifications)
RESEND_API_KEY=
